{
  "name": "saferent-ng",
  "version": "1.0.0",
  "description": "SafeRent is a web application designed to provide a secure and user-friendly platform for renting properties, It offers features such as property listings, user authentication, and a messaging system to facilitate communication between landlords and tenants.",
  "main": "main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "deploy": "gh-pages -d dist",
    "lint": "eslint *.js src/**/*.js",
    "format": "prettier --ignore-path ./.gitignore --write \"./**/*.{html,json,js,ts,css}\"",
    "test": "jest",
    "preview": "vite preview"
  },
  "author": "Theophilus Ajiri Menor",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.29.1",
    "gh-pages": "^6.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "vite": "^8.0.12"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "browserslist": [
    "last 3 and_chr versions",
    "last 3 chrome versions",
    "last 3 opera versions",
    "last 3 ios_saf versions",
    "last 3 safari versions"
  ]
}
